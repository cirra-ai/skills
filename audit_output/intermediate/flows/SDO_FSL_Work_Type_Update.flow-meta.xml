  "formulas": [
    {
      "name": "CalcAverageDelta",
      "dataType": "Number",
      "expression": "if({!NumSAs} == 0,0,\n\n({!TotalActual} - {!TotalEstimated})/{!NumSAs})",
      "scale": 2,
      "processMetadataValues": []
    },
    {
      "name": "CalcAvgActualDuration",
      "dataType": "Number",
      "expression": "if({!NumSAs} == 0,0,\n\n({!TotalActual} /{!NumSAs}))",
      "scale": 2,
      "processMetadataValues": []
    },
    {
      "name": "CalcAvgEstDuration",
      "dataType": "Number",
      "expression": "if({!NumSAs} == 0,0,\n\n({!TotalEstimated})/{!NumSAs})",
      "scale": 2,
      "processMetadataValues": []
    },
    {
      "name": "RecommendDuration",
      "dataType": "Number",
      "expression": "max(ceiling(( {!AvgEstimatedDuration} + {!Delta})/{!DurationIncrement})*{!DurationIncrement},0)",
      "scale": 0,
      "processMetadataValues": []
    },
    {
      "name": "updateMaxDelta",
      "dataType": "Number",
      "expression": "if(isblank({!thisSA.ActualDuration}) || isblank({!thisSA.DurationInMinutes}),{!MaxDelta},\n\nmax({!MaxDelta},{!thisSA.ActualDuration} - {!thisSA.DurationInMinutes}))",
      "scale": 2,
      "processMetadataValues": []
    },
    {
      "name": "updateMinDelta",
      "dataType": "Number",
      "expression": "if(isblank({!thisSA.ActualDuration}) || isblank({!thisSA.DurationInMinutes}),{!MinDelta},\nmin({!MinDelta},{!thisSA.ActualDuration} - {!thisSA.DurationInMinutes}))",
      "scale": 2,
      "processMetadataValues": []
    }
  ],
