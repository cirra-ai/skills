  "description": "Lightning Scheduler Demo Rest functionality.",
  "environments": "Default",
  "formulas": [
    {
      "name": "DateDifference",
      "dataType": "Number",
      "expression": "If(not(isblank({!New_Demo_Date})), {!New_Demo_Date} - datevalue({!LSEarliestDateFound}), {!Hours_Offset} / 24)",
      "scale": 6,
      "processMetadataValues": []
    },
    {
      "name": "NewDueDate",
      "dataType": "DateTime",
      "expression": "{!LS_SA.DueDate} + {!DateDifference}",
      "processMetadataValues": []
    },
    {
      "name": "NewEarlyStart",
      "dataType": "DateTime",
      "expression": "{!LS_SA.EarliestStartTime} + {!DateDifference}",
      "processMetadataValues": []
    },
    {
      "name": "NewSchedEndTime",
      "dataType": "DateTime",
      "expression": "{!LS_SA.SchedEndTime} + {!DateDifference}",
      "processMetadataValues": []
    },
    {
      "name": "NewSchedStartTime",
      "dataType": "DateTime",
      "expression": "{!LS_SA.SchedStartTime} + {!DateDifference}",
      "processMetadataValues": []
    },
    {
      "name": "SummaryMessage",
      "dataType": "String",
      "expression": "If(isblank({!Hours_Offset}), \"The new demo date is \" & text( {!New_Demo_Date}), \"The appointments have been moved by \" & text( {!Hours_Offset}) & \" hours\")",
      "processMetadataValues": []
    }
  ],
