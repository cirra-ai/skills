  "description": "Flow designed to run inside of the datatable CPE to select and set component attributes by interacting with a sample datatable.",
  "environments": "Default",
  "formulas": [
    {
      "name": "fFirstField",
      "dataType": "String",
      "expression": "TRIM(LEFT({!vConfigFields},FIND(\",\",{!vConfigFields})-1))",
      "processMetadataValues": []
    },
    {
      "name": "fGetFlexAttribute",
      "dataType": "String",
      "expression": "IF( {!vSeparatorLocation} > 0, RIGHT( {!vCombinedAttribute}, LEN( {!vCombinedAttribute} ) - {!vSeparatorLocation} - {!vSeparatorLength} + 1 ) , \"\" )",
      "processMetadataValues": []
    },
    {
      "name": "fGetWidthAttribute",
      "dataType": "String",
      "expression": "IF( {!vSeparatorLocation} > 0, LEFT( {!vCombinedAttribute}, {!vSeparatorLocation} - 1 ), {!vCombinedAttribute} )",
      "processMetadataValues": []
    },
    {
      "name": "fHasComma",
      "dataType": "Boolean",
      "expression": "FIND(\",\",{!vConfigFields})>0",
      "processMetadataValues": []
    },
    {
      "name": "fListLength",
      "dataType": "Number",
      "expression": "LEN({!vFieldList})",
      "scale": 0,
      "processMetadataValues": []
    },
    {
      "name": "fRemoveField",
      "dataType": "String",
      "expression": "MID({!vConfigFields},FIND(\",\",{!vConfigFields})+1,999)",
      "processMetadataValues": []
    },
    {
      "name": "fSeparatorLength",
      "dataType": "Number",
      "expression": "LEN( {!cSeparator} )",
      "scale": 0,
      "processMetadataValues": []
    },
    {
      "name": "fSeparatorLocation",
      "dataType": "Number",
      "expression": "FIND( {!cSeparator}, {!ConfigTable_select.outputSelectedRow.Widths__c} )",
      "scale": 0,
      "processMetadataValues": []
    },
    {
      "name": "fSetWidthFlexAttribute",
      "dataType": "String",
      "expression": "{!wiz_columnWidths} & IF( LEN( {!wiz_columnFlexes} ) > 0, {!cSeparator} & {!wiz_columnFlexes}, \"\" )",
      "processMetadataValues": []
    },
    {
      "name": "fTrimFieldList",
      "dataType": "String",
      "expression": "TRIM({!vFieldList})",
      "processMetadataValues": []
    }
  ],
