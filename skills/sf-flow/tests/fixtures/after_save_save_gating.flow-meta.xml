<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>Save-gating: this flow validates regulatory state after save and intentionally propagates faults to block invalid saves. Triggered after save because the validation requires the saved record's Id.</description>
    <label>Auto Regulatory Validation</label>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Audit_Flag</name>
        <label>Set Audit Flag</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterFormula>ISCHANGED({!$Record.Status__c})</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <connector>
            <targetReference>Set_Audit_Flag</targetReference>
        </connector>
    </start>
    <status>Draft</status>
</Flow>
