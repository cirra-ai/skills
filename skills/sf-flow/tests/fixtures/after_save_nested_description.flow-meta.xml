<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <actionCalls>
        <name>Send_Email_Action</name>
        <label>Send Email</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <description>save-gating helper note attached to this action call</description>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>emailAddresses</name>
            <value>
                <stringValue>sales-mgrs@example.com</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value>
                <stringValue>High-value opportunity</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <stringValue>Details</stringValue>
            </value>
        </inputParameters>
    </actionCalls>
    <description>Side-effect flow that notifies sales managers about high-value opportunities. This top-level description does not opt out of the save-blocking check.</description>
    <label>Auto Opportunity Nested Description</label>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterFormula>{!$Record.Amount} &gt; 100000</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <connector>
            <targetReference>Send_Email_Action</targetReference>
        </connector>
    </start>
    <status>Draft</status>
</Flow>
